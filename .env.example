# Copy to .env and fill in (never commit .env).
# Used when running load_claims.sh locally — Jenkins uses credential zxplore-db2-password instead.

export DB2_PASSWORD='your-zxplore-db2-password'
# Optional overrides (defaults match IBM Z Xplore JDBC-style CLP):
# export DB2_CONNECT_TARGET='204.90.115.200:5040/ZXPDB2'
# export DB2_USER='z77140'
# export DB2_SCHEMA='Z77140'
